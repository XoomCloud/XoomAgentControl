# ──────────────────────────────────────────────────────────────────────────
# XoomAgent Control Platform — environment variables
# Copy to .env and adjust. Never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# --- Database ---
DATABASE_URL="postgresql://xoom:xoom@localhost:5432/xoomagent?schema=public"

# --- Redis (queue / cache) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_HOST="0.0.0.0"
API_PORT="4000"
API_PUBLIC_URL="http://localhost:4000"
WEB_PUBLIC_URL="http://localhost:3000"
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000"

# --- Auth ---
# 32+ char random string used to sign admin session JWTs
JWT_SECRET="change-me-to-a-long-random-string-please-32+"
JWT_EXPIRES_IN="12h"
# Bootstrap admin user created on first `db:seed`
SEED_ADMIN_EMAIL="admin@xoomagent.local"
SEED_ADMIN_PASSWORD="changeme123!"

# --- Host agent auth ---
# Shared bootstrap token that lets a brand-new host call POST /api/hosts/register.
# After registration each host receives its own long-lived credential.
HOST_REGISTRATION_TOKEN="dev-host-registration-token"

# --- Secrets encryption (MVP envelope encryption) ---
# 32-byte key, base64 encoded. Generate: openssl rand -base64 32
SECRETS_MASTER_KEY="REPLACE_WITH_BASE64_32_BYTE_KEY"
# Provider for secrets: local | vault | infisical | doppler | aws
SECRETS_PROVIDER="local"

# --- LLM Gateway (LiteLLM) ---
LITELLM_BASE_URL="https://llm.xoomagent.local"
LITELLM_ADMIN_KEY=""

# --- Memory (Supermemory) ---
SUPERMEMORY_BASE_URL="https://api.supermemory.ai"
SUPERMEMORY_API_KEY=""

# --- Object storage (backups) ---
OBJECT_STORAGE_ENDPOINT="http://localhost:9000"
OBJECT_STORAGE_BUCKET="xoom-backups"
OBJECT_STORAGE_ACCESS_KEY=""
OBJECT_STORAGE_SECRET_KEY=""

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
