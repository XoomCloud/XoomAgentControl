# /etc/xoomagent/agent.env — copy and fill in, chmod 600
CONTROL_PLANE_URL=https://control.xoomagent.com
HOST_REGISTRATION_TOKEN=replace-with-bootstrap-token
HOST_NAME=hetzner-fsn1-01
HOST_LOCATION=fsn1
HOST_PUBLIC_IP=
HOST_PRIVATE_IP=
AGENT_STATE_PATH=/var/lib/xoomagent/agent-state.json
HEARTBEAT_INTERVAL_SECONDS=30
POLL_INTERVAL_SECONDS=5
# Set to false on a real KVM host to enable Firecracker provisioning.
AGENT_MOCK_MODE=true
TENANTS_DIR=/var/lib/xoomagent/tenants
FC_KERNEL_IMAGE=/var/lib/xoomagent/images/vmlinux.bin
FC_ROOTFS_BASE=/var/lib/xoomagent/images/rootfs.ext4
