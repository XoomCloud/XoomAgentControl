{
  "_comment": "Reference Firecracker machine config. The host agent renders this per tenant at provisioning time (see src/firecracker.ts). Placeholders: {{KERNEL}}, {{IP}}, {{ROOTFS}}, {{VCPU}}, {{RAM_MB}}, {{TAP}}.",
  "boot-source": {
    "kernel_image_path": "{{KERNEL}}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off ip={{IP}}::10.80.0.1:255.255.0.0::eth0:off"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "{{ROOTFS}}",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": {
    "vcpu_count": "{{VCPU}}",
    "mem_size_mib": "{{RAM_MB}}"
  },
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "host_dev_name": "{{TAP}}"
    }
  ]
}
