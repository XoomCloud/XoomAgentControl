{
  "name": "xoomagent-control-platform",
  "version": "0.1.0",
  "private": true,
  "description": "XoomAgent Control Platform — multi-tenant operations layer for isolated AI agent tenants on Firecracker MicroVMs running SwarmClaw.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./apps/**\" build",
    "dev:api": "pnpm --filter @xoom/api dev",
    "dev:web": "pnpm --filter @xoom/web dev",
    "dev:agent": "pnpm --filter @xoom/host-agent dev",
    "db:generate": "pnpm --filter @xoom/db generate",
    "db:migrate": "pnpm --filter @xoom/db migrate",
    "db:push": "pnpm --filter @xoom/db push",
    "db:seed": "pnpm --filter @xoom/db seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  }
}
